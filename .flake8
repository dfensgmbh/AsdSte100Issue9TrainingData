[flake8]
# Keep flake8 consistent with black (line-length = 80 in pyproject.toml).
max-line-length = 80
# E203: whitespace before ':' - conflicts with black's slice formatting
# W503: line break before binary operator - PEP 8 now prefers this style
extend-ignore = E203, W503
exclude =
    .git,
    .venv,
    __pycache__,
    build,
    dist,
    data,
    doc

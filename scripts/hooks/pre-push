#!/usr/bin/env bash
#
# Git pre-push hook: runs the fast CI checks before allowing a push.
#
# Skips pip-audit and build (network-heavy / slow). Bypass with:
#     git push --no-verify
#
# Install with:
#     scripts/install-hooks.sh     (Linux/macOS/Git-Bash)
#     pwsh scripts/install-hooks.ps1   (Windows PowerShell)
#
set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

if [[ -x ./scripts/ci-local.sh ]]; then
    exec ./scripts/ci-local.sh --skip pip-audit,build
elif command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -File ./scripts/ci-local.ps1 -Skip pip-audit,build
else
    echo "pre-push: neither bash ci-local.sh nor pwsh ci-local.ps1 could be run" >&2
    exit 1
fi
